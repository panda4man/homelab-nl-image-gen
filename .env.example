# This app's own Flask port. Also drives the Docker Compose host port mapping
# (compose reads this same file for variable substitution).
PORT=5001

# MCP server's port (mcp_server/). Also drives its Docker Compose host port mapping.
MCP_PORT=8000

# ComfyUI Server
COMFY_HOST=192.168.50.121
COMFY_PORT=8188

# Ollama LLM Server (workflow JSON generation)
LLM_HOST=192.168.50.46
LLM_PORT=11434
LLM_MODEL=qwen3:8b

# Ollama Embedding Server (optional, for future template routing)
EMBED_HOST=192.168.50.46
EMBED_PORT=11435

# --- Auth / sessions ---
# Flask session signing key. Generate with: python -c "import secrets;print(secrets.token_hex(32))"
SECRET_KEY=dev-insecure-change-me
# Shared secret the MCP server sends as X-API-Key (images -> origin='ai', unowned).
MCP_API_KEY=
# Google OAuth (OIDC). Leave blank to hide the "Sign in with Google" button.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Public base URL browsers use (e.g. https://host.tailnet.ts.net), for the Google
# callback. Blank -> derived from the incoming request.
OAUTH_REDIRECT_BASE=
